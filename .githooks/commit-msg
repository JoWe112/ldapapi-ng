#!/usr/bin/env bash
# commit-msg: enforce conventional commit format
# See: https://www.conventionalcommits.org/

set -euo pipefail

RED='\033[0;31m'
NC='\033[0m'

MSG_FILE="$1"
MSG=$(cat "$MSG_FILE")

# Skip merge commits, fixup, squash
if echo "$MSG" | grep -qE '^(Merge|Revert|fixup!|squash!)'; then
    exit 0
fi

PATTERN='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\(.+\))?(!)?: .{1,100}'

if ! echo "$MSG" | grep -qE "$PATTERN"; then
    echo -e "${RED}[BLOCKED] Commit message does not follow Conventional Commits format.${NC}"
    echo ""
    echo "Expected: <type>(<scope>): <description>"
    echo "Types: feat | fix | docs | style | refactor | perf | test | build | ci | chore | revert"
    echo ""
    echo "Examples:"
    echo "  feat(auth): add LDAP group membership support"
    echo "  fix: handle nil pointer in search handler"
    echo "  chore!: drop Go 1.20 support"
    echo ""
    echo "Your message: $MSG"
    exit 1
fi

exit 0
