#!/usr/bin/env bash
# pre-commit: scan staged files for secrets and dangerous patterns

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null) || true
[ -z "$STAGED" ] && exit 0

# Get diff of non-hook files only to avoid false positives from the hook itself
DIFF=$(git diff --cached --unified=0 -- \
    $(git diff --cached --name-only --diff-filter=ACM | grep -v '^\.githooks/') 2>/dev/null) || true

FAIL=0

# --- 1. Private key detection ---
if echo "$DIFF" | grep -qE -- 'BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY'; then
    echo -e "${RED}[BLOCKED] Private key detected in staged changes.${NC}"
    FAIL=1
fi

# --- 2. Common secret patterns in added lines ---
SECRET_PATTERN='(password|passwd|secret|api_key|apikey|access_token|auth_token|private_key)\s*[=:]\s*["'"'"']?[A-Za-z0-9+/\-_.]{8,}'
if echo "$DIFF" | grep -iE "^\+.*${SECRET_PATTERN}" | grep -qvE '(example|placeholder|changeme|xxx|todo|\$\{|\{\{)'; then
    echo -e "${RED}[BLOCKED] Possible hardcoded secret in staged changes:${NC}"
    echo "$DIFF" | grep -iE "^\+.*${SECRET_PATTERN}" | grep -vE '(example|placeholder|changeme|xxx|todo|\$\{|\{\{)' | head -5
    FAIL=1
fi

# --- 3. AWS access key pattern ---
if echo "$DIFF" | grep -qE '^\+.*(AKIA|ASIA|AROA)[0-9A-Z]{16}'; then
    echo -e "${RED}[BLOCKED] AWS access key detected in staged changes.${NC}"
    FAIL=1
fi

# --- 4. GitHub tokens ---
if echo "$DIFF" | grep -qE '^\+.*(ghp_|ghs_|gho_|github_pat_)[A-Za-z0-9_]{36,}'; then
    echo -e "${RED}[BLOCKED] Possible GitHub token in staged changes.${NC}"
    FAIL=1
fi

# --- 5. Dangerous file types ---
DANGEROUS_EXTENSIONS='(\.pem|\.key|\.p12|\.pfx|\.jks|\.keystore|_rsa|_ed25519|_ecdsa)$'
for f in $STAGED; do
    if echo "$f" | grep -qiE "$DANGEROUS_EXTENSIONS"; then
        echo -e "${RED}[BLOCKED] Dangerous file type staged: $f${NC}"
        FAIL=1
    fi
done

# --- 6. Merge conflict markers ---
for f in $STAGED; do
    if git show ":$f" 2>/dev/null | grep -qE '^(<{7}|>{7}|={7})'; then
        echo -e "${RED}[BLOCKED] Merge conflict markers in: $f${NC}"
        FAIL=1
    fi
done

# --- 7. Large file warning (>1MB) ---
for f in $STAGED; do
    SIZE=$(git cat-file -s ":$f" 2>/dev/null || echo 0)
    if [ "$SIZE" -gt 1048576 ]; then
        echo -e "${YELLOW}[WARNING] Large file staged ($(( SIZE / 1024 ))KB): $f${NC}"
        echo -e "${YELLOW}Consider using Git LFS for large assets.${NC}"
    fi
done

if [ "$FAIL" -eq 1 ]; then
    echo ""
    echo -e "${RED}Commit blocked. Fix the issues above before committing.${NC}"
    echo "To bypass (ONLY if you are certain this is a false positive):"
    echo "  git commit --no-verify"
    exit 1
fi

exit 0
